# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/test-results/
/blob-report/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
/debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local agent / assistant tooling (worktrees, session state) — never project source
/.claude/
/.agents/
/.codex/

# local scratch & cleanup staging — never project source
/_to_delete/
/_export/
*.tgz
*.tar.gz

# ad-hoc in-tree git worktrees (should live outside the repo, ignored if created here)
/.pb2-followup-wt/

# generated Playwright auth storageState (live session cookies) — never commit
/e2e/.auth/

# raw owner-supplied image exports (ChatGPT PNGs, ~30MB) — never web-served;
# only the selected/converted WebP files under public/landing/ are tracked.
# asset-map.json (file -> section -> use/hold/flagged/reference) is the one
# exception — it's the deterministic spec for that conversion and is meant
# to be committed and diffed.
/brand/images/*
!/brand/images/asset-map.json
