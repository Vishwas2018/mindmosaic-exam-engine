# Copy to .env.local and fill in for this device. Never commit .env.local
# (see .gitignore's `.env*` rule) — these are secrets, not placeholders.

# Public Supabase project config — safe to ship to the client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Grants full database access, bypassing RLS. Required for
# parent-provisioned student sign-up (src/features/auth/provision-child.ts) —
# without it, provisioning fails cleanly with a "not configured" message
# rather than crashing. Read only in server-side code via
# process.env.SUPABASE_SERVICE_ROLE_KEY; never prefix with NEXT_PUBLIC_,
# never import into any client component, never commit a real value.
SUPABASE_SERVICE_ROLE_KEY=
