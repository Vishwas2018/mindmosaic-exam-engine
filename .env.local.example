# Copy to .env.local and fill in for this device. Never commit .env.local
# (see .gitignore's `.env*` rule) — these are secrets, not placeholders.

# Public Supabase project config — safe to ship to the client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Grants full database access, bypassing RLS. Required for
# parent-provisioned student sign-up (src/features/auth/provision-child.ts) —
# without it, provisioning fails cleanly with a "not configured" message
# rather than crashing. Read only in server-side code via
# process.env.SUPABASE_SERVICE_ROLE_KEY; never prefix with NEXT_PUBLIC_,
# never import into any client component, never commit a real value.
SUPABASE_SERVICE_ROLE_KEY=

# Question-factory AI provider adapter (src/features/question-factory/ai).
# Server-only — read via process.env, never prefixed with NEXT_PUBLIC_,
# never logged, never committed with a real value. Selects and configures
# the provider `questions:generate-ai`/`questions:review-ai` call; with
# QF_AI_PROVIDER unset (or its matching key unset) both CLIs stop cleanly
# with a "configure a provider key" message instead of running live.
QF_AI_PROVIDER=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional model overrides (defaults: claude-sonnet-5 / gpt-4o).
QF_AI_ANTHROPIC_MODEL=
QF_AI_OPENAI_MODEL=

# Server-only. Billing enforcement kill switch (Batch 3,
# docs/PRIVACY_AND_BILLING_GUARDRAILS.md) — see
# src/features/billing/require-active-subscription.ts. Defaults off (unset
# or anything other than the literal "true"), which makes the parent/student
# subscription gate a complete no-op. Only set to "true" once /billing
# (Batch 4) exists to redirect to. Never gates guests or unauthenticated
# /practice — that guarantee holds regardless of this flag.
BILLING_ENFORCEMENT_ENABLED=

# Stripe (Phase 6 billing plumbing — src/lib/stripe/**, src/app/api/stripe/**).
# Card data itself never touches our servers (Stripe Checkout/Elements only,
# per docs/PRIVACY_AND_BILLING_GUARDRAILS.md); these are the keys that let
# our server talk to Stripe and verify Stripe's webhook calls.

# Server-only secret key. Read via process.env.STRIPE_SECRET_KEY in
# src/lib/stripe/client.ts; never prefix with NEXT_PUBLIC_, never import
# into any client component, never commit a real value.
STRIPE_SECRET_KEY=

# Server-only webhook signing secret, used to verify that a POST to
# /api/stripe/webhook genuinely came from Stripe before any billing-state
# write is trusted. Same server-only rules as STRIPE_SECRET_KEY above.
STRIPE_WEBHOOK_SECRET=

# Public: safe to ship to the client (Stripe Elements/Checkout.js would read
# this browser-side if this codebase used them directly). Not yet consumed
# by any code in this batch — no UI exists yet — but reserved here since the
# batch contract names it as a required var.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Server-only. Stripe Price IDs for the one Family plan's two billing
# cadences (Stripe Dashboard -> Product catalogue). Not part of the
# original three-var contract for this batch, but unavoidable: a Checkout
# Session cannot be created without a price id. Left empty,
# /api/stripe/checkout fails clean with `plan_not_configured` instead of
# calling Stripe with a blank price. See src/lib/stripe/config.ts.
STRIPE_PRICE_FAMILY_MONTHLY=
STRIPE_PRICE_FAMILY_ANNUAL=
