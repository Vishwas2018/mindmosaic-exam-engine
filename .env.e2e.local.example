# Copy to .env.e2e.local (gitignored) and fill in. Read ONLY by the
# authenticated Playwright suite (playwright.auth.config.ts, e2e/fixtures/**,
# e2e/setup/**) — never by the main app or by `npm run dev`. See
# docs/testing/playwright-auth-test-data-guide.md.
#
# This is deliberately a separate file from `.env.local`: this repo's own
# `.env.local` points at a real hosted Supabase project for day-to-day app
# development. The authenticated e2e suite must never be able to read that
# project's URL/keys, even by accident — environment-guard.ts refuses to run
# against anything but 127.0.0.1/localhost regardless of what's here, but
# keeping the files separate means there is no real credential anywhere near
# this one to guard against in the first place.
#
# Start local Supabase first (`supabase start` — see supabase/config.toml),
# then fill these in from its own output. The URL/anon/service-role values
# below are the Supabase CLI's published local-development demo values —
# identical on every machine that runs the local stack, and not secrets
# (see https://supabase.com/docs/guides/local-development/cli/config) — filled
# in here so the file works out of the box after `supabase start`. Confirm
# they match your own `supabase start` output before relying on them.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:56321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# Fixture credentials for every seeded parent/teacher/admin identity (one
# shared password) and every seeded student identity (one shared PIN). Not
# real accounts, not real secrets — but keep this file out of git anyway
# (it's `.env*`-ignored) since anyone with local Supabase running and these
# values could sign in as the fixtures.
E2E_FIXTURE_PASSWORD=Fixture-Password-123!
E2E_FIXTURE_STUDENT_PIN=194728
